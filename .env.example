# Copie este arquivo para .env e preencha as chaves reais
# NUNCA commite o arquivo .env

# FaceCheck.ID — busca facial
# Cadastro: https://facecheck.id
FACECHECK_API_KEY=...

# Google Cloud Vision — busca reversa de imagem
# Crie em: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLOUD_API_KEY=...
# ou use o caminho para o arquivo de credenciais do Google Cloud:
# GOOGLE_APPLICATION_CREDENTIALS=...

# Amazon Rekognition — validação facial dos resultados
# Crie em: console.aws.amazon.com → IAM → Users → Access keys
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# AWS S3 — bucket privado para presigned URL temporária (SerpAPI)
# Criar bucket em: console.aws.amazon.com/s3 (manter Block all public access ativado)
# As credenciais AWS acima (ACCESS_KEY_ID / SECRET_ACCESS_KEY) são reaproveitadas
AWS_S3_BUCKET=poc-dossie-temp

# SerpAPI — busca reversa complementar (google_reverse_image)
# Cadastro: https://serpapi.com → Dashboard → API Key
# Plano gratuito: 100 buscas/mês
SERPAPI_KEY=...
